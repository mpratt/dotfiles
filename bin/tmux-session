#!/usr/bin/env python3

import yaml
import subprocess
import sys
import os

def merge_windows(config_file, windows_dict, seen):
    """Merge a config file's windows into windows_dict, following includes.

    Includes are processed recursively and deduped by resolved path, so a
    shared include reached through several parents (e.g. agent-guiacereza.yml
    pulled in by both api and guiacereza) is only pulled in once - the first
    occurrence wins and later duplicates are ignored.
    """
    config_file = os.path.abspath(config_file)
    script_dir = os.path.dirname(config_file)

    with open(config_file, 'r') as f:
        config = yaml.safe_load(f)

    # Resolve this file's own root/folder for its panes
    folder = config.get('root') or config.get('folder')
    if folder and not os.path.isabs(folder):
        folder = os.path.join(script_dir, folder)

    # A singleton config (e.g. a shared agents window) is never duplicated:
    # its windows are added at most once and never get extra panes merged in.
    is_singleton = bool(config.get('singleton'))

    for window in config.get('windows', []):
        window_name = list(window.keys())[0]
        window_data = window[window_name].copy()

        # Convert panes to objects with folder info
        panes = window_data.get('panes', [])
        panes_with_folder = [{'command': cmd, 'folder': folder} for cmd in panes]

        # If window exists, merge panes; otherwise create new entry
        if window_name in windows_dict:
            # Never merge panes into (or out of) a singleton window - keep it
            # a single pane no matter how many configs reference it.
            if is_singleton or windows_dict[window_name].get('_singleton'):
                continue
            existing_panes = windows_dict[window_name].get('panes', [])
            windows_dict[window_name]['panes'] = existing_panes + panes_with_folder
            # Mark as merged to use vertical splits
            windows_dict[window_name]['_merged'] = True
        else:
            window_data['panes'] = panes_with_folder
            if folder:
                window_data['_folder'] = folder
            if is_singleton:
                window_data['_singleton'] = True
            windows_dict[window_name] = window_data

    # Recurse into includes, deduping by resolved path
    for include_file in config.get('include', []) or []:
        if os.path.isabs(include_file):
            include_path = os.path.abspath(include_file)
        else:
            include_path = os.path.abspath(os.path.join(script_dir, include_file))
        if include_path in seen:
            continue
        seen.add(include_path)
        merge_windows(include_path, windows_dict, seen)

def load_config(config_file):
    """Load a config file and resolve includes (recursively, deduped)"""
    config_file = os.path.abspath(config_file)
    script_dir = os.path.dirname(config_file)

    with open(config_file, 'r') as f:
        config = yaml.safe_load(f)

    # Use dict to merge windows with same name across the include tree
    windows_dict = {}
    merge_windows(config_file, windows_dict, {config_file})

    # Convert dict back to list format and sort alphabetically
    all_windows = [{name: data} for name, data in windows_dict.items()]
    if all_windows:
        all_windows.sort(key=lambda w: list(w.keys())[0].lower())

    # Set the combined windows list
    if all_windows:
        config['windows'] = all_windows
        config['_default_folder'] = script_dir

    return config

def main():
    config_file = sys.argv[1] if len(sys.argv) > 1 else 'api.guiacereza.com.yml'
    config = load_config(config_file)

    session_name = config['name']
    default_folder = config.get('root') or config.get('folder') or config.get('_default_folder') or os.getcwd()

    # Resolve relative folder path
    if not os.path.isabs(default_folder):
        script_dir = os.path.dirname(os.path.abspath(config_file))
        default_folder = os.path.join(script_dir, default_folder)

    # Check if session exists
    result = subprocess.run(['tmux', 'has-session', '-t', session_name],
                          capture_output=True)
    if result.returncode == 0:
        print(f"Session '{session_name}' already exists. Attaching...")
        subprocess.run(['tmux', 'attach-session', '-t', session_name])
        return

    # Create new session
    subprocess.run(['tmux', 'new-session', '-d', '-s', session_name, '-c', default_folder])

    for i, window in enumerate(config['windows']):
        window_name = list(window.keys())[0]
        window_data = window[window_name]

        # Get panes, layout, and folder from window data
        panes = window_data.get('panes', [])
        layout = window_data.get('layout', 'tiled')
        window_folder = window_data.get('_folder', default_folder)
        is_merged = window_data.get('_merged', False)

        if i == 0:
            # Rename first window (already created with session)
            subprocess.run(['tmux', 'rename-window', '-t', f'{session_name}', window_name])
        else:
            # Create new window
            subprocess.run(['tmux', 'new-window', '-t', f'{session_name}',
                          '-n', window_name, '-c', window_folder])

        # Select the window
        subprocess.run(['tmux', 'select-window', '-t', f'{session_name}:{window_name}'])

        for j, pane in enumerate(panes):
            # Extract command and folder from pane object
            if isinstance(pane, dict):
                command = pane['command']
                pane_folder = pane.get('folder') or window_folder
            else:
                # Fallback for non-dict panes (shouldn't happen with new code)
                command = pane
                pane_folder = window_folder

            if j == 0:
                # Send cd command first, then the actual command to first pane
                subprocess.run(['tmux', 'send-keys', '-t', f'{session_name}:{window_name}.0',
                              f'cd {pane_folder}', 'C-m'])
                subprocess.run(['tmux', 'send-keys', '-t', f'{session_name}:{window_name}.0',
                              command, 'C-m'])
            else:
                # Split window and send command
                # Use vertical split (-h) for merged windows, horizontal otherwise
                split_cmd = ['tmux', 'split-window', '-t', f'{session_name}:{window_name}']
                if is_merged:
                    split_cmd.append('-h')
                split_cmd.extend(['-c', pane_folder])
                subprocess.run(split_cmd)
                subprocess.run(['tmux', 'send-keys', '-t', f'{session_name}:{window_name}.{j}',
                              f'cd {pane_folder}', 'C-m'])
                subprocess.run(['tmux', 'send-keys', '-t', f'{session_name}:{window_name}.{j}',
                              command, 'C-m'])

        # Apply layout (use even-horizontal for merged windows to keep them side by side)
        if is_merged:
            subprocess.run(['tmux', 'select-layout', '-t', f'{session_name}:{window_name}', 'even-horizontal'])
        else:
            subprocess.run(['tmux', 'select-layout', '-t', f'{session_name}:{window_name}', layout])

    # Select the first window
    first_window_name = list(config['windows'][0].keys())[0]
    subprocess.run(['tmux', 'select-window', '-t', f'{session_name}:{first_window_name}'])

    # Attach to session
    subprocess.run(['tmux', 'attach-session', '-t', session_name])

if __name__ == '__main__':
    main()
