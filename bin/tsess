##################################################################
APPNAME="Tmux Session Selector"
VERSION="2.0"
WD="${HOME}/Projects"

##################################################################
# Run script
##################################################################
if ! [ -e "${WD}" ]; then
    echo "Directory ${WD} doesn't exist"
    exit 1
fi

# Find all yaml/yml files in tmux-session folders (2 levels deep)
# Structure: /home/projects/*/(_)?tmux-session/*.{yaml,yml}
cd "${WD}"

# Build a list of yaml files with their relative paths
yaml_files=()
for project in */; do
    if [ -d "${project}_tmux-sessions" ]; then
        for yaml in "${project}_tmux-sessions"/*.yaml "${project}_tmux-sessions"/*.yml; do
            if [ -f "$yaml" ]; then
                yaml_files+=("$yaml")
            fi
        done
    fi

    if [ -d "${project}tmux-sessions" ]; then
        for yaml in "${project}tmux-sessions"/*.yaml "${project}tmux-sessions"/*.yml; do
            if [ -f "$yaml" ]; then
                yaml_files+=("$yaml")
            fi
        done
    fi
done

if [ ${#yaml_files[@]} -eq 0 ]; then
    echo "No yaml files found in tmux-session folders"
    exit 1
fi

# Use fzf to select a yaml file
# If an argument is passed, use it as the initial query
if [ -n "$1" ]; then
    selected_yaml=$(printf '%s\n' "${yaml_files[@]}" | fzf --query "$1")
else
    selected_yaml=$(printf '%s\n' "${yaml_files[@]}" | fzf)
fi

if [ -z "$selected_yaml" ]; then
    echo "No file selected"
    exit 0
fi

# Get the full path to the selected yaml
yaml_path="${WD}/${selected_yaml}"
yaml_file=$(basename "$selected_yaml")

# Extract root/folder from the yaml file to cd into it
root_dir=$(python3 -c "
import yaml, os, sys
with open('$yaml_path') as f:
    config = yaml.safe_load(f)
root = config.get('root') or config.get('folder') or ''
if root and not os.path.isabs(root):
    root = os.path.join(os.path.dirname('$yaml_path'), root)
print(root)
")

if [ -n "$root_dir" ] && [ -d "$root_dir" ]; then
    echo "Running tmux-session with: $yaml_file (root: $root_dir)"
    cd "$root_dir"
else
    echo "Running tmux-session with: $yaml_file"
    cd "$(dirname "$yaml_path")"
fi

tmux-session "$yaml_path"
